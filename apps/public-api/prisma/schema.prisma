generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectStatus {
  IDEA
  VALIDATING
  DEVELOPING
  RELEASED
  GROWING
  PAUSED
  PIVOTED
}

enum DonationStatus {
  CREATED
  DONE
  CANCELED
  FAILED
}

enum MessagePublicStatus {
  NONE
  PENDING
  APPROVED
  HIDDEN
  REJECTED
}

enum UserRole {
  CREATOR
  ADMIN
  SUPER_ADMIN
}

enum AdminAuditAction {
  ROLE_UPDATED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CREATOR)
  roleAssignedAt DateTime?
  roleAssignedById String?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  sessions      Session[]
  ownedProjects Project[] @relation("ProjectOwner")
  followers     Follow[]  @relation("Following")
  following     Follow[]  @relation("Follower")

  @@index([role])
}

model AdminAuditLog {
  id          String           @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  targetUserId String?
  targetEmail String
  action      AdminAuditAction
  previousRole UserRole?
  nextRole    UserRole
  metadata    Json?
  createdAt   DateTime         @default(now())

  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Project {
  id             String               @id @default(cuid())
  ownerId        String?
  owner          User?                @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  deletedById    String?
  deletedAt      DateTime?
  slug           String               @unique
  name           String
  tagline        String
  detailContent  String               @default("")
  websiteUrl     String
  supportUrl     String
  thumbnailUrl   String
  status         ProjectStatus        @default(IDEA)
  voteCount      Int                  @default(0)
  commentCount   Int                  @default(0)
  tags           String[]             @default([])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  events         AnalyticsEvent[]
  feedback       Feedback[]
  waitlist       Waitlist[]
  embedSettings  EmbedProjectSettings?
  donations      Donation[]

  @@index([ownerId])
  @@index([createdAt])
  @@index([deletedAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String
  projectId String?
  sessionId String
  timestamp DateTime @default(now())
  metadata  Json?

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([projectId, timestamp])
  @@index([sessionId])
}

model Feedback {
  id        String   @id @default(cuid())
  projectId String
  sessionId String
  comment   String
  sentiment String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Waitlist {
  id        String   @id @default(cuid())
  projectId String
  email     String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([projectId])
}

model EmbedProjectSettings {
  id                String              @id @default(cuid())
  projectId         String              @unique
  creatorName       String
  headline          String
  description       String
  buttonText        String              @default("후원하기")
  checkoutText      String              @default("결제하기")
  theme             String              @default("sunset")
  currency          String              @default("KRW")
  presetAmounts     Int[]               @default([5000, 10000, 30000])
  minAmount         Int                 @default(1000)
  maxAmount         Int                 @default(500000)
  campaign          String              @default("default")
  paymentMethod     String              @default("CARD")
  note              String?
  accentColor       String?
  requireSignedEmbed Boolean            @default(true)
  moderateMessages  Boolean             @default(false)
  publicMessages    Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allowedOrigins    EmbedAllowedOrigin[]
  donations         Donation[]
}

model EmbedAllowedOrigin {
  id         String               @id @default(cuid())
  settingsId String
  origin     String
  createdAt  DateTime             @default(now())

  settings   EmbedProjectSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@unique([settingsId, origin])
  @@index([origin])
}

model Donation {
  id                  String               @id @default(cuid())
  projectId           String
  settingsId          String?
  orderId             String               @unique
  status              DonationStatus       @default(CREATED)
  amount              Int
  currency            String
  orderName           String
  creator             String
  campaign            String               @default("default")
  supporterName       String?
  message             String?
  messagePublicStatus MessagePublicStatus  @default(NONE)
  originUrl           String?
  checkoutUrl         String?
  paymentKey          String?
  receiptUrl          String?
  method              String?
  provider            String?
  pageUrl             String?
  lastWebhookEvent    String?
  confirmedPayload    Json?
  approvedAt          DateTime?
  creatorReadAt       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  settings            EmbedProjectSettings? @relation(fields: [settingsId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([status, createdAt])
  @@index([projectId, status, approvedAt])
  @@index([projectId, creatorReadAt, approvedAt])
}

model LegacyDashboardUser {
  id             BigInt                @id @default(autoincrement())
  provider       String                @default("supabase")
  providerUserId String                @map("provider_user_id")
  email          String
  displayName    String?               @map("display_name")
  avatarUrl      String?               @map("avatar_url")
  role           String                @default("project_admin")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  creatorProjects LegacyCreatorProject[]

  @@unique([provider, providerUserId])
  @@map("dashboard_users")
}

model LegacyCreatorProject {
  id                 String              @id @db.VarChar(80)
  ownerUserId        BigInt              @map("owner_user_id")
  name               String              @db.VarChar(120)
  websiteUrl         String?             @map("website_url")
  allowedOrigins     String[]            @default([]) @map("allowed_origins")
  requireSignedEmbed Boolean             @default(true) @map("require_signed_embed")
  moderateMessages   Boolean             @default(false) @map("moderate_messages")
  publicMessages     Boolean             @default(true) @map("public_messages")
  archivedAt         DateTime?           @map("archived_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  ownerUser          LegacyDashboardUser @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
  @@map("creator_projects")
}
