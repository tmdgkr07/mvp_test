{
  "name": "mvp-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n dashboard,api,widget \"npm run dev:dashboard\" \"npm run dev:api\" \"npm run dev:widget\"",
    "dev:dashboard": "npm run dev --workspace @mvp-platform/dashboard-web",
    "dev:api": "npm run dev --workspace @mvp-platform/public-api",
    "dev:widget": "npm run dev --workspace @mvp-platform/widget-cdn",
    "build": "npm run build --workspace @mvp-platform/dashboard-web && npm run build --workspace @mvp-platform/public-api && npm run build --workspace @mvp-platform/widget-cdn",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "start:dashboard": "npm run start --workspace @mvp-platform/dashboard-web",
    "start:api": "npm run start --workspace @mvp-platform/public-api",
    "start:widget": "npm run start --workspace @mvp-platform/widget-cdn",
    "db:generate": "npm run db:generate --workspace @mvp-platform/dashboard-web",
    "db:push": "npm run db:push --workspace @mvp-platform/dashboard-web",
    "db:secure": "npm run db:secure --workspace @mvp-platform/dashboard-web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
